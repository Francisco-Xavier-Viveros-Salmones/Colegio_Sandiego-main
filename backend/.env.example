# ============================================================
# SAE COLEGIO SAN DIEGO - VARIABLES DE ENTORNO DE DESARROLLO
# Copiar este archivo como .env dentro de backend/.
# No subir backend/.env al repositorio.
# ============================================================

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Base de datos local.
# Debe coincidir con docker-compose.yml si se levanta solo postgres_sae.
DATABASE_URL="postgresql://sae_admin:SaeColegio2026@localhost:5432/sae_colegio_san_diego"
DATABASE_PROVIDER=postgresql

# Secreto de desarrollo. En produccion cambiarlo por uno propio de 32+ caracteres.
JWT_SECRET=desarrollo_sae_colegio_sandiego_2026_secret_local
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
LOG_LEVEL=dev

BACKUP_DIR=../backups

POSTGRES_PASSWORD=SaeColegio2026
POSTGRES_USER=sae_admin
POSTGRES_DB=sae_colegio_san_diego
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
