# ============================================================
# SAE Colegio San Diego — backend/.dockerignore
# Excluye archivos innecesarios del contexto de build Docker.
# ============================================================

# Dependencias: se instalan dentro del contenedor con npm ci
node_modules

# Logs de npm / yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Variables de entorno (se inyectan vía docker-compose environment)
.env
.env.local
.env.*.local
# Preservar el ejemplo de referencia
!.env.example

# Tests y cobertura
coverage/
.nyc_output/
tests/
__tests__/
*.test.js
*.spec.js
vitest.config.js

# Logs del sistema
logs/
*.log

# Base de datos SQLite (solo modo desarrollo sin Docker; producción usa PostgreSQL)
prisma/prisma/sae.db
prisma/prisma/sae.db-journal
prisma/prisma/sae.db-wal
prisma/prisma/sae.db-shm

# Backups locales (gestionados por el volumen Docker sae_backups)
backups/

# Herramientas de desarrollo (no requeridas en la imagen de producción)
.eslintrc.cjs
.eslintignore
.prettierrc
.prettierignore

# Control de versiones
.git
.gitignore

# Docker (ya está en el contexto)
Dockerfile
.dockerignore

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/
